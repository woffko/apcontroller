#!/bin/sh

#
# (c) 2025 Cezary Jackiewicz <cezary@eko.one.pl>
#

SEC=$1
[ -z "$SEC" ] && exit 0

VERBOSE=$2

. /usr/share/libubox/jshn.sh

BASEPATH="/tmp/apcontroller"
T=$(uci -q get apcontroller.@global[0].path)
[ -n "$T" ] && BASEPATH="$T"
mkdir -p "$BASEPATH"

log_apcontroller() {
	logger -t apcontroller-sendconfig "$*"
}

default_keyfile() {
	echo "/root/.ssh/id_apc_$1"
}

normalize_keyfile() {
	local section="$1"
	local keyfile="$2"
	local default

	default="$(default_keyfile "$section")"

	case "$keyfile" in
		""|"/root/.ssh/id_dropbear")
			echo "$default"
			;;
		/root/.ssh/id_apc_*)
			[ "$keyfile" = "$default" ] && echo "$keyfile" || echo "$default"
			;;
		*)
			echo "$keyfile"
			;;
	esac
}

setup_missing_key() {
	local host="$1"
	local name="$2"
	local ipaddr="$3"
	local keyfile="$4"
	local errfile="$5"
	local password="$6"

	if [ -z "$password" ]; then
		log_apcontroller "Failed to send config to ${name} (${ipaddr}): Key file '${keyfile}' is missing and no password is stored for key setup."
		return 1
	fi

	if [ ! -x /usr/libexec/rpcd/apcontroller ]; then
		log_apcontroller "Failed to send config to ${name} (${ipaddr}): Key file '${keyfile}' is missing and ssh_setup helper is unavailable."
		return 1
	fi

	log_apcontroller "Key file '${keyfile}' for ${name} (${ipaddr}) is missing; running SSH key setup."
	printf '{"section":"%s"}\n' "$host" | /usr/libexec/rpcd/apcontroller call ssh_setup >"$errfile" 2>&1

	if [ -e "$keyfile" ]; then
		log_apcontroller "Key setup for ${name} (${ipaddr}) created '${keyfile}'."
		return 0
	fi

	log_apcontroller "Failed to send config to ${name} (${ipaddr}): Key file '${keyfile}' is still missing after setup: $(tr '\n' ' ' < "$errfile")"
	return 1
}

T=$(uci -q get apcontroller."$SEC")
[ "x$T" = "xgroup" ] || exit 0

HOSTS=$(uci -q get apcontroller."$SEC".host)
[ -z "$HOSTS" ] && exit 0
WIFIS=$(uci -q get apcontroller."$SEC".wifi)
[ -z "$WIFIS" ] && exit 0

json_init

DELETE=$(uci -q get apcontroller."$SEC".delete)
[ "x$DELETE" = "x1" ] && json_add_int "delete" 1

json_add_array "wifis"
for WIFI in $WIFIS; do
	BANDS="$(uci -q get apcontroller."$WIFI".band)"
	for BAND in $BANDS; do
		json_add_object
		json_add_int "enabled" "$(uci -q get apcontroller."$WIFI".enabled)"
		json_add_string "band" "$BAND"
		json_add_string "ssid" "$(uci -q get apcontroller."$WIFI".ssid)"
		json_add_string "encryption" "$(uci -q get apcontroller."$WIFI".encryption)"
		json_add_string "key" "$(uci -q get apcontroller."$WIFI".key)"
		json_add_int "hidden" "$(uci -q get apcontroller."$WIFI".hidden)"
		json_add_int "isolate" "$(uci -q get apcontroller."$WIFI".isolate)"
		json_add_string "network" "$(uci -q get apcontroller."$WIFI".network)"
		json_close_object
	done
done
json_close_array

json_dump > ${BASEPATH}/cmds-${SEC}

USEAS=$(uci -q get apcontroller."$SEC".useadditionalscript)
ERRFILE="${BASEPATH}/sendconfig.err"

for HOST in $HOSTS; do
	enabled=$(uci -q get apcontroller."$HOST".enabled)
	[ "$enabled" -eq 1 ] || continue

	ipaddr=$(uci -q get apcontroller."$HOST".ipaddr)
	[ -z "$ipaddr" ] && continue
	port=$(uci -q get apcontroller."$HOST".port)
	[ -z "$port" ] && port=22
	username=$(uci -q get apcontroller."$HOST".username)
	[ -z "$username" ] && continue
	password=$(uci -q get apcontroller."$HOST".password)
	NAME=$(uci -q get apcontroller."$HOST".name)

	autokeysetup=$(uci -q get apcontroller."$HOST".autokeysetup)
	usekeyfile=$(uci -q get apcontroller."$HOST".usekeyfile)
	keyfile=$(uci -q get apcontroller."$HOST".keyfile)
	if [ "x$autokeysetup" = "x1" ]; then
		keyfile="$(default_keyfile "$HOST")"
		keyauth=1
	else
		keyfile="$(normalize_keyfile "$HOST" "$keyfile")"
		keyauth="$usekeyfile"
	fi

	# Common SSH options for compatibility with older Dropbear/RSA
	SSH_OPTS="-o BatchMode=yes -o StrictHostKeyChecking=yes -o UserKnownHostsFile=/root/.ssh/known_hosts -o PubkeyAcceptedAlgorithms=+ssh-rsa -o HostKeyAlgorithms=+ssh-rsa -o ConnectTimeout=15"
	SCP_OPTS="-O -B"
	PASS_SSH_OPTS="-o StrictHostKeyChecking=no -o PubkeyAcceptedAlgorithms=+ssh-rsa -o HostKeyAlgorithms=+ssh-rsa -o ConnectTimeout=15"
	PASS_SCP_OPTS="-O"

	rm -f "$ERRFILE"
	T=1

	if [ "x$keyauth" = "x1" ]; then
		if [ ! -e "$keyfile" ]; then
			if [ "x$autokeysetup" = "x1" ]; then
				setup_missing_key "$HOST" "$NAME" "$ipaddr" "$keyfile" "$ERRFILE" "$password"
			else
				log_apcontroller "Failed to send config to ${NAME} (${ipaddr}): Custom key file '${keyfile}' is missing."
			fi
		fi

		if [ -e "$keyfile" ]; then
			if command -v dbclient >/dev/null 2>&1 && dropbearkey -y -f "$keyfile" >/dev/null 2>&1; then
				DBCLIENT_OPTS="-q -i ${keyfile} -o BatchMode=yes -o PasswordAuthentication=no -o StrictHostKeyChecking=accept-new -p ${port} -l ${username}"
				if [ "x$USEAS" = "x1" ]; then
					dbclient $DBCLIENT_OPTS "$ipaddr" "cat > /tmp/apcontroller.user && chmod 755 /tmp/apcontroller.user" < /usr/share/apcontroller/apcontroller.user 2>"$ERRFILE" && \
					dbclient $DBCLIENT_OPTS "$ipaddr" "cat > /tmp/apcontroller-agent-as && chmod 755 /tmp/apcontroller-agent-as" < /usr/share/apcontroller/apcontroller-agent-as 2>>"$ERRFILE"
					T=$?
				else
					T=0
				fi
				[ "$T" -eq 0 ] && \
				dbclient $DBCLIENT_OPTS "$ipaddr" "cat > /tmp/cmds-${SEC}" < ${BASEPATH}/cmds-${SEC} 2>>"$ERRFILE" && \
				dbclient $DBCLIENT_OPTS "$ipaddr" "cat > /tmp/apcontroller-agent-setconfig && chmod 755 /tmp/apcontroller-agent-setconfig" < /usr/share/apcontroller/apcontroller-agent-setconfig 2>>"$ERRFILE" && \
				dbclient $DBCLIENT_OPTS "$ipaddr" "/tmp/apcontroller-agent-setconfig /tmp/cmds-${SEC}" 2>>"$ERRFILE"
				T=$?
			else
				if [ "x$USEAS" = "x1" ]; then
					scp $SCP_OPTS -i "${keyfile}" $SSH_OPTS -P ${port} /usr/share/apcontroller/apcontroller.user "${username}@${ipaddr}:/tmp" 2>"$ERRFILE"
					scp $SCP_OPTS -i "${keyfile}" $SSH_OPTS -P ${port} /usr/share/apcontroller/apcontroller-agent-as "${username}@${ipaddr}:/tmp" 2>>"$ERRFILE"
				fi
				scp $SCP_OPTS -i "${keyfile}" $SSH_OPTS -P ${port} ${BASEPATH}/cmds-${SEC} "${username}@${ipaddr}:/tmp" 2>>"$ERRFILE" && \
				scp $SCP_OPTS -i "${keyfile}" $SSH_OPTS -P ${port} /usr/share/apcontroller/apcontroller-agent-setconfig "${username}@${ipaddr}:/tmp" 2>>"$ERRFILE" && \
				ssh -q -i "${keyfile}" $SSH_OPTS -o PreferredAuthentications=publickey -p ${port} "${username}@${ipaddr}" "/tmp/apcontroller-agent-setconfig /tmp/cmds-${SEC}" 2>>"$ERRFILE"
				T=$?
			fi
		else
			T=1
		fi
	fi

	if [ "x$keyauth" != "x1" ]; then
		# Password auth only if key auth is disabled
		if [ "x$USEAS" = "x1" ]; then
			sshpass -p "${password}" scp $PASS_SCP_OPTS $PASS_SSH_OPTS -P ${port} /usr/share/apcontroller/apcontroller.user "${username}@${ipaddr}:/tmp" 2>"$ERRFILE"
			sshpass -p "${password}" scp $PASS_SCP_OPTS $PASS_SSH_OPTS -P ${port} /usr/share/apcontroller/apcontroller-agent-as "${username}@${ipaddr}:/tmp" 2>>"$ERRFILE"
		fi
		sshpass -p "${password}" scp $PASS_SCP_OPTS $PASS_SSH_OPTS -P ${port} ${BASEPATH}/cmds-${SEC} "${username}@${ipaddr}:/tmp" 2>>"$ERRFILE" && \
		sshpass -p "${password}" scp $PASS_SCP_OPTS $PASS_SSH_OPTS -P ${port} /usr/share/apcontroller/apcontroller-agent-setconfig "${username}@${ipaddr}:/tmp" 2>>"$ERRFILE" && \
		sshpass -p "${password}" ssh -q $PASS_SSH_OPTS -p ${port} "${username}@${ipaddr}" "/tmp/apcontroller-agent-setconfig /tmp/cmds-${SEC}" 2>>"$ERRFILE"
		T=$?
	fi

	if [ "$T" -ne 0 ]; then
		ERR_MSG=$(tr '\n' ' ' < "$ERRFILE" | sed 's/  */ /g')
		log_apcontroller "Failed to send config to ${NAME} (${ipaddr}): ${ERR_MSG:-unknown error}"
	fi

	if [ -n "$VERBOSE" ]; then
		[ "$T" -eq 0 ] && RET="OK" || RET="ERROR"
		echo "${NAME} (${ipaddr}): ${RET}"
	fi
done

rm -f ${BASEPATH}/cmds-${SEC} "$ERRFILE" 2>/dev/null

exit 0
